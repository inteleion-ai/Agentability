# Agentability Platform — Environment Variables
# Copy to platform/.env and adjust for your environment.
# The platform API reads these at startup via os.getenv().

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file.
# Use an absolute path in production to avoid working-directory surprises.
# When sharing with AFMX (offline mode), point both to the same file:
#   AFMX:        AFMX_AGENTABILITY_DB_PATH=/home/opc/agentability.db
#   Agentability: AGENTABILITY_DB=/home/opc/agentability.db
AGENTABILITY_DB=agentability.db

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Default (when unset): http://localhost:3000 and http://localhost:5173
# Production example:
#   AGENTABILITY_CORS_ORIGINS=https://app.mycompany.com,https://afmx.mycompany.com
# Dev with AFMX dashboard:
#   AGENTABILITY_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8100
AGENTABILITY_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Feature Flags ──────────────────────────────────────────────────────────────
# Set to true to expose /metrics Prometheus endpoint
AGENTABILITY_PROMETHEUS_ENABLED=true

# ── Auth (future) ──────────────────────────────────────────────────────────────
# API key authentication — not yet enforced in v0.2.x
# AGENTABILITY_API_KEY=your-secret-key-here
